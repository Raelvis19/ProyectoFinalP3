<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="400.0" prefWidth="710.0"
           stylesheets="@../../resources/style/style.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="main.java.app.MainController">

    <children>

        <!-- 🔹 Contenido centrado -->
        <VBox alignment="CENTER" spacing="25">

            <children>

                <!-- Puntaje -->
                <VBox alignment="CENTER" spacing="5">
                    <children>
                        <Label text="Puntaje Mas Alto:" styleClass="texto" translateY="220"/>
                        <Label text="0.00" styleClass="score" translateY="220"/>
                    </children>
                </VBox>

                <!-- Botón jugar -->
                <Button mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="120.0"
                        text="JUGAR"
                        translateY="250"/>

            </children>

        </VBox>

        <!-- 🔊 Botón sonido (FUERA del VBox) -->
        <Button fx:id="btnSound"
                onAction="#toggleSound"
                StackPane.alignment="TOP_RIGHT"
                prefWidth="40"
                prefHeight="40"
                styleClass="sound">


            <StackPane.margin>
                <Insets top="15" right="15"/>
            </StackPane.margin>

        </Button>

        <Button fx:id="btnAyuda"
                onAction="#ayuda"
                StackPane.alignment ="TOP_RIGHT"
                prefWidth="120"
                prefHeight="120"
                styleClass="ayuda">
            <StackPane.margin>
                <Insets top="100" right="20"/>
                    </StackPane.margin>

                </Button>


                <VBox fx:id="panelAyuda"
              alignment="CENTER"
              visible="false"
              styleClass="panel-ayuda">

            <children>
                <Label text="PANTALLA DE AYUDA"/>
                
            </children>

        </VBox>

            

        

    </children>

    

</StackPane>